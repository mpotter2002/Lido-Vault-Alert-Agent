# .env.local.example
# Copy to .env.local and fill in real values.
# .env.local is git-ignored and never committed.

# ---------------------------------------------------------------------------
# Ethereum RPC
# ---------------------------------------------------------------------------
# Used to read live vault state (totalAssets, paused) and wallet positions.
# Default: https://cloudflare-eth.com (public, no key, rate-limited)
# Recommended: your own Alchemy / Infura / QuickNode mainnet endpoint.
# ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# ---------------------------------------------------------------------------
# Monitored wallet (fallback for API routes when no wallet param is passed)
# ---------------------------------------------------------------------------
# MONITORED_WALLET=0xYourWalletAddress

# ---------------------------------------------------------------------------
# Telegram bot
# ---------------------------------------------------------------------------
# 1. Create a bot via @BotFather → /newbot → copy the token here.
# 2. TELEGRAM_CHAT_ID is optional — only needed for the old single-user
#    /api/telegram-send route. The public bot uses subscriber-based delivery.
# 3. After deploying, register your webhook once:
#    GET /api/telegram-register-webhook
#    (set APP_URL to your deployed URL first)
#
TELEGRAM_BOT_TOKEN=

# Optional — legacy single-user send path
# TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------------
# App URL (needed for webhook registration)
# ---------------------------------------------------------------------------
# Set to your deployed Vercel URL. Used by /api/telegram-register-webhook.
# APP_URL=https://your-app.vercel.app

# ---------------------------------------------------------------------------
# Supabase (subscriber store)
# ---------------------------------------------------------------------------
# Create a project at supabase.com, run the schema migration, then fill these in.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---------------------------------------------------------------------------
# Email alerts (optional — Gmail SMTP via Nodemailer)
# ---------------------------------------------------------------------------
# 1. Enable 2-Step Verification on your Google account
# 2. Go to myaccount.google.com/apppasswords → generate an App Password
# 3. Fill in your Gmail address and the generated App Password below
# If not set, email alerts are silently skipped (Telegram still works).
#
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
#
# Supabase migration — add the email column to your subscribers table:
#   ALTER TABLE subscribers ADD COLUMN IF NOT EXISTS email TEXT;
