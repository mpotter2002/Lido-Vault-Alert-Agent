# .env.local.example
# Copy to .env.local and fill in real values.
# .env.local is git-ignored and never committed.

# ---------------------------------------------------------------------------
# Ethereum RPC
# ---------------------------------------------------------------------------
# Used by lib/wallet-reader.ts to read vault share balances on-chain.
# Default: https://cloudflare-eth.com (public, no key, rate-limited)
# Recommended: your own Alchemy / Infura / QuickNode mainnet endpoint.
# ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# ---------------------------------------------------------------------------
# Telegram delivery
# ---------------------------------------------------------------------------
# Required for POST /api/telegram-send and scripts/send-telegram.mjs.
#
# 1. Create a bot via @BotFather → copy the token here.
# 2. Add the bot to your channel/group and get the chat_id:
#      a. Send a message in the channel
#      b. Visit https://api.telegram.org/bot<TOKEN>/getUpdates
#      c. Copy the "chat": { "id": ... } value (negative for channels/groups)
#
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
